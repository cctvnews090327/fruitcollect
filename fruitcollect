task.spawn(function()
    while true do
        if autoCollectOn then
            local n = autoCollectStep()
            if n > 0 then
                task.wait(AUTO_LOOP_WAIT)
            else
                task.wait(IDLE_LOOP_WAIT)
            end
        else
            task.wait(0.5)
        end
    end
end)

