local MUT_COLORS = {
    Gold=Color3.fromRGB(255,200,40), Rainbow=Color3.fromRGB(255,120,220),
    Electric=Color3.fromRGB(255,230,80), Frozen=Color3.fromRGB(120,200,255),
    Bloodlit=Color3.fromRGB(200,40,60), Chained=Color3.fromRGB(140,140,160),
    Starstruck=Color3.fromRGB(255,240,150), Aurora=Color3.fromRGB(232,139,255),
}
local function colorFor(mut)
    if MUT_COLORS[mut] then return MUT_COLORS[mut] end
    local h = 0
    for i = 1, #mut do h = (h * 31 + string.byte(mut, i)) % 360 end
    local r = math.abs((h        % 360) / 360 - 0.5) * 510
    local g = math.abs(((h+120)  % 360) / 360 - 0.5) * 510
    local b = math.abs(((h+240)  % 360) / 360 - 0.5) * 510
    return Color3.fromRGB(math.clamp(255-r,80,255), math.clamp(255-g,80,255), math.clamp(255-b,80,255))
end

local function fmtMoney(v)
    if v >= 1_000_000_000 then return string.format("$%.2fB", v/1_000_000_000) end
    if v >= 1_000_000     then return string.format("$%.2fM", v/1_000_000) end
    if v >= 1_000         then return string.format("$%.1fK", v/1_000) end
    return "$"..tostring(v)
end

