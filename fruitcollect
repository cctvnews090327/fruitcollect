    local tierBadge = Instance.new("TextLabel", row)
    tierBadge.Size = UDim2.new(0,32,0,22); tierBadge.Position = UDim2.new(0,6,0.5,-11)
    tierBadge.BackgroundColor3 = tier.color; tierBadge.BorderSizePixel = 0
