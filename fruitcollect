    styleFruitChip(b, selectedFruits[seedName] == true)
    b.MouseButton1Click:Connect(function()
        if selectedFruits[seedName] then
            selectedFruits[seedName] = nil
        else
            selectedFruits[seedName] = true
        end
        styleFruitChip(b, selectedFruits[seedName] == true)
    end)
    return b
end

local function rebuildFruitChips(counts)
    for _, c in pairs(fruitChips) do c:Destroy() end
    fruitChips = {}
    local names = {}
    for n in pairs(counts) do table.insert(names, n) end
    table.sort(names)
    for _, n in ipairs(names) do
        fruitChips[n] = makeFruitChip(n, counts[n])
    end
end

