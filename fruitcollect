    kgBadge.BackgroundColor3 = colorForSize(size); kgBadge.BorderSizePixel = 0
    kgBadge.Font = Enum.Font.GothamBold; kgBadge.TextSize = 11
    kgBadge.TextColor3 = Color3.fromRGB(20,20,20)
    -- show trailing ~ if we're guessing on the base kg
    kgBadge.Text = string.format("%.2fkg%s", weight, resolved and "" or "~")
    Instance.new("UICorner", kgBadge).CornerRadius = UDim.new(0,4)

    local nameLbl = Instance.new("TextLabel", row)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Size = UDim2.new(0,130,1,0); nameLbl.Position = UDim2.new(0,76,0,0)
    nameLbl.Font = Enum.Font.GothamSemibold; nameLbl.TextSize = 12
    nameLbl.TextColor3 = Color3.fromRGB(235,235,250); nameLbl.Text = seedName
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local hasMut = mut and mut ~= ""
    local badgeText = ""
    if hasMut then
        local mx = MUT_MULTI[mut]
        local eff = mutationFactor(seedName, mut)
        if mx and mx > 1 then
            if SINGLE_HARVEST[seedName] then
                badgeText = string.format("%s x%.2f", mut, eff)
            else
                badgeText = string.format("%s x%g", mut, mx)
            end
        else
            badgeText = mut
        end
    end
    local badgeW = hasMut and math.max(70, #badgeText * 7 + 14) or 0

    local valLbl = Instance.new("TextLabel", row)
    valLbl.BackgroundTransparency = 1
    valLbl.Size = UDim2.new(0, 78, 1, 0)
    valLbl.Position = UDim2.new(1, -(badgeW + (hasMut and 72 or 10) + 64), 0, 0)
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 12
    valLbl.TextColor3 = Color3.fromRGB(120,255,160)
    valLbl.Text = val > 0 and fmtMoney(val) or "-"
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local sizeLbl = Instance.new("TextLabel", row)
    sizeLbl.BackgroundTransparency = 1
    sizeLbl.Size = UDim2.new(0,72,1,0)
    sizeLbl.Position = UDim2.new(1, -(badgeW + (hasMut and 72 or 10)), 0, 0)
    sizeLbl.Font = Enum.Font.GothamBold; sizeLbl.TextSize = 12
    sizeLbl.TextColor3 = Color3.fromRGB(255,220,120)
    sizeLbl.Text = string.format("x%.2f", size)
    sizeLbl.TextXAlignment = Enum.TextXAlignment.Right

    if hasMut then
        local mBadge = Instance.new("TextLabel", row)
        mBadge.Size = UDim2.new(0, badgeW, 0, 20)
        mBadge.Position = UDim2.new(1, -(badgeW + 8), 0.5, -10)
        mBadge.BackgroundColor3 = colorFor(mut); mBadge.BorderSizePixel = 0
        mBadge.Font = Enum.Font.GothamBold; mBadge.TextSize = 11
        mBadge.TextColor3 = Color3.fromRGB(20,20,20); mBadge.Text = badgeText
        Instance.new("UICorner", mBadge).CornerRadius = UDim.new(0,4)
    end
    return row
end

local function clearList()
    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
end

local function scan()
    clearList()
    local plot = findPlot()
    if not plot then summary.Text = "❌ No plot."; return end
    local plants = plot:FindFirstChild("Plants")
    if not plants then summary.Text = "❌ No Plants folder."; return end

    local rows, mutCount, mutTypes, total = {}, 0, {}, 0
    local underThresh = 0
    local fruitCounts = {}
    for _, plant in ipairs(plants:GetChildren()) do
        local seed = plant:GetAttribute("SeedName") or "?"
        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in ipairs(fruits:GetChildren()) do
                total += 1
                fruitCounts[seed] = (fruitCounts[seed] or 0) + 1
                local size = fruit:GetAttribute("SizeMulti") or 0
                local mut  = fruit:GetAttribute("Mutation")
                local val  = valueOf(seed, size, mut)
                if kgOf(seed, size) < kgThreshold then underThresh += 1 end
                if mut and mut ~= "" then
                    mutCount += 1
                    mutTypes[mut] = (mutTypes[mut] or 0) + 1
                end
                table.insert(rows, {fruit=fruit, plant=plant, seed=seed, size=size, mut=mut, val=val})
            end
        end
    end
    table.sort(rows, function(a, b)
        if a.val ~= b.val then return a.val > b.val end
        return a.size > b.size
    end)
    for i, r in ipairs(rows) do makeRow(r.fruit, r.seed, i).Parent = scroll end

    rebuildFruitChips(fruitCounts)

    local mline = ""
    for m, c in pairs(mutTypes) do mline = mline..string.format("%s:%d  ", m, c) end
    local resolvedCount = 0
    for _ in pairs(BASE_KG) do resolvedCount += 1 end
    summary.Text = string.format(
        "Plot: %s  |  Fruits: %d  |  <%.2fkg: %d  |  Mutated: %d  |  BaseKg: %d seeds%s",
        plot.Name, total, kgThreshold, underThresh, mutCount, resolvedCount,
        mline ~= "" and "\n"..mline or "")
end

-- ---------- collect ----------
local function fireCollect(plant, fruit)
    local pid = plant:GetAttribute("PlantId")
    local fid = fruit:GetAttribute("FruitId")
    if not pid or not fid then return false end
    return pcall(function()
        Networking.Garden.CollectFruit:Fire(pid, fid)
    end)
end

local function collectAllMutated()
    local plot = findPlot()
    if not plot or not plot:FindFirstChild("Plants") then return 0 end
    local count = 0
    pcall(function() lp.ReplicationFocus = lp.Character end)
    for _, plant in ipairs(plot.Plants:GetChildren()) do
        local seed = plant:GetAttribute("SeedName") or "?"
        if fruitAllowed(seed) then
            local fruits = plant:FindFirstChild("Fruits")
            if fruits then
                for _, fruit in ipairs(fruits:GetChildren()) do
                    local mut = fruit:GetAttribute("Mutation")
                    if mut and typeof(mut) == "string" and mut ~= "" then
                        if fireCollect(plant, fruit) then
                            count += 1; task.wait(PER_FRUIT_WAIT)
                        end
                    end
                end
            end
        end
    end
    return count
end

local function collectInRanges()
    local plot = findPlot()
    if not plot or not plot:FindFirstChild("Plants") then return 0 end
    if not anyRangeSelected(selectedRanges) then return 0 end
    local count = 0
    pcall(function() lp.ReplicationFocus = lp.Character end)
    for _, plant in ipairs(plot.Plants:GetChildren()) do
        local seed = plant:GetAttribute("SeedName") or "?"
        if fruitAllowed(seed) then
            local fruits = plant:FindFirstChild("Fruits")
            if fruits then
                for _, fruit in ipairs(fruits:GetChildren()) do
                    local size   = fruit:GetAttribute("SizeMulti") or 0
                    local mut    = fruit:GetAttribute("Mutation")
                    local age    = fruit:GetAttribute("Age") or 0
                    local maxAge = fruit:GetAttribute("MaxAge") or 0
                    if age >= maxAge and maxAge > 0 then
                        local val = valueOf(seed, size, mut)
                        if inAnySelectedRange(val, selectedRanges) then
                            if fireCollect(plant, fruit) then
                                count += 1; task.wait(PER_FRUIT_WAIT)
                            end
                        end
                    end
                end
            end
        end
    end
    return count
end

-- Auto loop = threshold cleanup mode. Collects 2 fruits per tick in parallel
-- and flags an instant sell after each pair.
local function autoCollectStep()
    local plot = findPlot()
    if not plot or not plot:FindFirstChild("Plants") then return 0 end
    pcall(function() lp.ReplicationFocus = lp.Character end)
    local batch = {}
    for _, plant in ipairs(plot.Plants:GetChildren()) do
        local seed = plant:GetAttribute("SeedName") or "?"
        if fruitAllowed(seed) then
            local fruits = plant:FindFirstChild("Fruits")
            if fruits then
                for _, fruit in ipairs(fruits:GetChildren()) do
                    local size   = fruit:GetAttribute("SizeMulti") or 0
                    local age    = fruit:GetAttribute("Age") or 0
                    local maxAge = fruit:GetAttribute("MaxAge") or 0
                    local ripe   = (maxAge > 0 and age >= maxAge)
                                or (maxAge == 0)
                                or (fruit:GetAttribute("Ripe") == true)
                    if ripe and kgOf(seed, size) < kgThreshold then
                        table.insert(batch, {plant, fruit, nil})
                    end
                end
            else
                -- single-harvest plants: no Fruits folder, use ProximityPrompt
                if SINGLE_HARVEST[seed] then
                    local hp = plant:FindFirstChild("HarvestPart")
                    local prompt = hp and hp:FindFirstChildOfClass("ProximityPrompt")
                    local growReady = plant:GetAttribute("PlantGrowthReady")
                    if prompt and growReady and kgOf(seed, 1) < kgThreshold then
                        table.insert(batch, {plant, nil, prompt})
                    end
                end
            end
        end
    end

    local function fireItem(item)
        if item[3] then
            pcall(function()
                item[3].Parent.CFrame = lp.Character.HumanoidRootPart.CFrame
                fireproximityprompt(item[3])
            end)
        else
            fireCollect(item[1], item[2])
        end
    end

    local count = 0
    for i = 1, #batch, 2 do
        local a = batch[i]
        local b = batch[i+1]
        task.spawn(function() fireItem(a) end)
        if b then
            task.spawn(function() fireItem(b) end)
            count += 2
        else
            count += 1
        end
        pendingSell = true
        task.wait(PER_FRUIT_WAIT)
    end

    -- retry sweep: re-fire anything the wrapper silently dropped
    task.wait(0.15)
    for _, item in ipairs(batch) do
        local fruit = item[2]
        if fruit and fruit.Parent then
            task.spawn(function() fireItem(item) end)
            pendingSell = true
        end
    end

    return count
end

