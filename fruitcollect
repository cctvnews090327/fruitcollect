local function fireCollect(plant, fruit)
    local pid = plant:GetAttribute("PlantId")
    local fid = fruit:GetAttribute("FruitId")
    if not pid or not fid then return false end
    return pcall(function()
        Networking.Garden.CollectFruit:Fire(pid, fid)
    end)
end

local function collectAllMutated()
    local plot = findPlot()
    if not plot or not plot:FindFirstChild("Plants") then return 0 end
    local count = 0
    pcall(function() lp.ReplicationFocus = lp.Character end)
    for _, plant in ipairs(plot.Plants:GetChildren()) do
        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in ipairs(fruits:GetChildren()) do
                local mut = fruit:GetAttribute("Mutation")
                if mut and typeof(mut) == "string" and mut ~= "" then
                    if fireCollect(plant, fruit) then
                        count += 1; task.wait(PER_FRUIT_WAIT)
                    end
                end
            end
        end
    end
    return count
end

local function collectInRanges()
    local plot = findPlot()
    if not plot or not plot:FindFirstChild("Plants") then return 0 end
    if not anyRangeSelected(selectedRanges) then return 0 end
    local count = 0
    pcall(function() lp.ReplicationFocus = lp.Character end)
    for _, plant in ipairs(plot.Plants:GetChildren()) do
        local seed = plant:GetAttribute("SeedName") or "?"
        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in ipairs(fruits:GetChildren()) do
                local size   = fruit:GetAttribute("SizeMulti") or 0
                local mut    = fruit:GetAttribute("Mutation")
                local age    = fruit:GetAttribute("Age") or 0
                local maxAge = fruit:GetAttribute("MaxAge") or 0
                if age >= maxAge and maxAge > 0 then
                    local val = valueOf(seed, size, mut)
                    if inAnySelectedRange(val, selectedRanges) then
                        if fireCollect(plant, fruit) then
                            count += 1; task.wait(PER_FRUIT_WAIT)
                        end
                    end
                end
            end
        end
    end
    return count
end

local function autoCollectStep()
    local plot = findPlot()
    if not plot or not plot:FindFirstChild("Plants") then return 0 end
    local useRanges = anyRangeSelected(selectedRanges)
    local count = 0
    pcall(function() lp.ReplicationFocus = lp.Character end)
    for _, plant in ipairs(plot.Plants:GetChildren()) do
        local seed = plant:GetAttribute("SeedName") or "?"
        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in ipairs(fruits:GetChildren()) do
                local size   = fruit:GetAttribute("SizeMulti") or 0
                local mut    = fruit:GetAttribute("Mutation")
                local age    = fruit:GetAttribute("Age") or 0
                local maxAge = fruit:GetAttribute("MaxAge") or 0
                if age >= maxAge and maxAge > 0 then
                    local match = false
                    if useRanges then
                        local val = valueOf(seed, size, mut)
                        if inAnySelectedRange(val, selectedRanges) then match = true end
                    else
                        local tier = tierOf(size)
                        if selectedTiers[tier.name] then match = true end
                    end
                    if match and fireCollect(plant, fruit) then
                        count += 1; task.wait(PER_FRUIT_WAIT)
                    end
                end
            end
        end
    end
    return count
end

