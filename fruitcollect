-- ===== per-seed base kg discovery =====
-- We scan ReplicatedStorage for modules whose values look like fruit records
-- and pull out weight-like fields. This is best-effort; misses fall back to
-- FALLBACK_KG so the script still works.
local BASE_KG = {}

local WEIGHT_KEYS = {
    "BaseWeight","BaseKg","BaseKG","BaseSize","Weight","Kg","KG",
    "baseWeight","baseKg","baseSize","weight","kg",
    "DefaultWeight","AverageWeight","AvgWeight",
}

local function extractWeight(record)
    if typeof(record) ~= "table" then return nil end
    for _, key in ipairs(WEIGHT_KEYS) do
        local v = record[key]
        if typeof(v) == "number" and v > 0 then return v end
    end
    -- nested: record.Stats.Weight etc
    for _, sub in pairs(record) do
        if typeof(sub) == "table" then
            for _, key in ipairs(WEIGHT_KEYS) do
                local v = sub[key]
                if typeof(v) == "number" and v > 0 then return v end
            end
        end
    end
    return nil
end

local function scanModule(mod)
    local ok, data = pcall(require, mod)
    if not ok or typeof(data) ~= "table" then return end
    for k, v in pairs(data) do
        if typeof(k) == "string" and SVD[k] then  -- known seed name
            local w = extractWeight(v)
            if w then BASE_KG[k] = w end
        end
    end
end

local function scanForBaseKg()
    local scanned = 0
    local function walk(root)
        for _, child in ipairs(root:GetChildren()) do
            if child:IsA("ModuleScript") then
                local n = child.Name:lower()
                if n:find("fruit") or n:find("seed") or n:find("plant")
                   or n:find("weight") or n:find("size") or n:find("data")
                   or n:find("info") or n:find("config") then
                    scanModule(child)
                    scanned += 1
                    if scanned > 40 then return end
                end
            elseif child:IsA("Folder") or child:IsA("Configuration") then
                walk(child)
            end
        end
    end
    pcall(function() walk(RS) end)
end
scanForBaseKg()

local function baseKgOf(seedName)
    return BASE_KG[seedName] or FALLBACK_KG
end

local function kgOf(seedName, sizeMulti)
    return baseKgOf(seedName) * (sizeMulti or 0)
end

-- ===== REAL formula from FruitValueCalc =====
local SIZE_EXPONENT_DEFAULT = 2.65
local SIZE_EXPONENT_OVERRIDES = { Mushroom = 1.9, Bamboo = 1.75 }
local KNEE          = 5
local TAIL_EXPONENT = 1.5
local SINGLE_HARVEST_SCALE = 0.15
local MIN_VALUES = { Carrot = 4 }

local SINGLE_HARVEST = {
    Carrot=true, Tulip=true, Bamboo=true, Mushroom=true, ["Green Bean"]=true,
}

local MUT_MULTI = {
    Gold=10, Rainbow=30, Electric=25, Frozen=14,
    Bloodlit=60, Chained=8, Starstruck=50, Aurora=1.5,
}

local function sizeFactor(seedName, size)
    local exp = SIZE_EXPONENT_OVERRIDES[seedName] or SIZE_EXPONENT_DEFAULT
    if size <= KNEE then return size ^ exp end
    return (KNEE ^ exp) * ((size / KNEE) ^ math.min(TAIL_EXPONENT, exp))
end

local function mutationFactor(seedName, mut)
    if not mut or mut == "" then return 1 end
    local m = MUT_MULTI[mut] or 1
    if SINGLE_HARVEST[seedName] and m > 1 then
        return 1 + (m - 1) * SINGLE_HARVEST_SCALE
    end
    return m
end

local function valueOf(seedName, size, mut)
    local base = SVD[seedName]
    if not base then return 0 end
    local v = math.floor(base * sizeFactor(seedName, size or 0) * mutationFactor(seedName, mut))
    local minV = MIN_VALUES[seedName]
    if minV and v < minV then v = minV end
    return v
end

