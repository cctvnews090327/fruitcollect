    valLbl.BackgroundTransparency = 1
    valLbl.Size = UDim2.new(0, 78, 1, 0)
    valLbl.Position = UDim2.new(1, -(badgeW + (hasMut and 72 or 10) + 64), 0, 0)
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 12
    valLbl.TextColor3 = Color3.fromRGB(120,255,160)
    valLbl.Text = val > 0 and fmtMoney(val) or "-"
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local sizeLbl = Instance.new("TextLabel", row)
    sizeLbl.BackgroundTransparency = 1
    sizeLbl.Size = UDim2.new(0,60,1,0)
    sizeLbl.Position = UDim2.new(1, -(badgeW + (hasMut and 72 or 10)), 0, 0)
    sizeLbl.Font = Enum.Font.GothamBold; sizeLbl.TextSize = 12
    sizeLbl.TextColor3 = Color3.fromRGB(255,220,120)
    sizeLbl.Text = string.format("x%.2f", size)
